<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:vm="http://www.mulesoft.org/schema/mule/vm"
	xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/vm http://www.mulesoft.org/schema/mule/vm/current/mule-vm.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
                          http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">

    

    <error-handler name="orders-error-handler">

    <!-- HANDLE ONLY VALIDATION ERRORS -->
    <on-error-continue type="VALIDATION:*">

        <logger level="ERROR" message="#['Error Handler Entry | type=' ++ (error.errorType as String) ++ ' | description=' ++ (error.description default '') ++ ' | correlationId=' ++ (vars.correlationId default correlationId) ++ ' | flow=' ++ flow.name ++ ' | orderId=' ++ (vars.orderId default 'UNKNOWN') ++ ' | rootCause=' ++ (error.cause.message default 'none')]" doc:name="Log Validation Error Entry"/>

        <!-- WHY: preserve original message -->

        <!-- WHY: standard structure -->
        <set-variable variableName="errorResponse" value="#[%dw 2.0
output application/java
---
read(MuleRuntime.loadFile('dwl/validation-error-response.dwl'), 'application/dw')(error, vars, correlationId)]" doc:name="Set error Response Variable"/>

        <!-- WHY: build DLQ structure -->
        <set-payload value="#[%dw 2.0
output application/java
---
read(MuleRuntime.loadFile('dwl/validation-dlq-payload.dwl'), 'application/dw')(vars)]" doc:name="Set Error Payload"/>

        <!-- WHY: send ONLY validation errors -->
        <vm:publish queueName="ijm-error-queue"
                    config-ref="vm-config-order"
                    sendCorrelationId="ALWAYS" doc:name="Publish to DLQ"/>

    </on-error-continue>

    <on-error-continue type="HTTP:*" doc:name="Handle HTTP Errors">

        <logger level="ERROR" message="#['Error Handler Entry | type=' ++ (error.errorType as String) ++ ' | description=' ++ (error.description default '') ++ ' | correlationId=' ++ (vars.correlationId default correlationId) ++ ' | flow=' ++ flow.name ++ ' | orderId=' ++ (vars.orderId default 'UNKNOWN') ++ ' | rootCause=' ++ (error.cause.message default 'none')]" doc:name="Log HTTP Error Entry"/>

        <!-- Build error response -->
        <set-variable variableName="errorResponse" value="#[%dw 2.0
output application/java
---
read(MuleRuntime.loadFile('dwl/http-error-response.dwl'), 'application/dw')(error, vars, correlationId)]" doc:name="Set error Response Variable"/>

        <!-- DLQ payload -->
        <set-payload value="#[%dw 2.0
output application/java
---
read(MuleRuntime.loadFile('dwl/http-dlq-payload.dwl'), 'application/dw')(vars)]" doc:name="Set Error Payload"/>

        <!-- Push to DLQ -->
        <vm:publish queueName="ijm-error-queue"
                    config-ref="vm-config-order"
                    sendCorrelationId="ALWAYS" doc:name="Publish to DLQ"/>

    </on-error-continue>

    </error-handler>

</mule>